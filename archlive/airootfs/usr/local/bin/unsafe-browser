#!/bin/bash
# unsafe-browser — launch Firefox with a separate profile for non-sensitive browsing
# NOTE: All traffic still routes through Tor via transparent proxy.
# For true direct networking, use: unshare -n firefox (then configure networking manually)

set -euo pipefail

FIREFOX_PROFILE="${HOME}/.mozilla/firefox/unsafe"

# Create profile if missing with warning config
if [ ! -d "$FIREFOX_PROFILE" ]; then
  mkdir -p "$FIREFOX_PROFILE"
  cat > "${FIREFOX_PROFILE}/user.js" << 'EOF'
user_pref("network.proxy.socks", "");
user_pref("network.proxy.socks_port", 0);
user_pref("network.proxy.type", 0);
user_pref("privacy.clearOnShutdown.history", true);
user_pref("privacy.clearOnShutdown.cookies", true);
user_pref("privacy.clearOnShutdown.cache", true);
user_pref("browser.startup.homepage", "about:blank");
user_pref("signon.rememberSignons", false);
user_pref("browser.formfill.enable", false);
user_pref("toolkit.telemetry.enabled", false);
user_pref("browser.shell.checkDefaultBrowser", false);
EOF
fi

# Show warning
notify-send -u critical "⚠ UNSAFE BROWSER" "Traffic still routes through Tor. Close when done." -t 5000
echo ""
echo "  ╔══════════════════════════════════════════════════╗"
echo "  ║           UNSAFE BROWSER (separate profile)     ║"
echo "  ║     Traffic still goes through Tor proxy        ║"
echo "  ║   For direct networking: unshare -n firefox     ║"
echo "  ╚══════════════════════════════════════════════════╝"
echo ""

exec firefox --no-remote --profile "$FIREFOX_PROFILE" "$@"
