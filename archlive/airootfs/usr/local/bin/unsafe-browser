#!/bin/bash
# unsafe-browser — launch Firefox with DIRECT networking (bypass Tor)
# Uses a separate network namespace with direct routing.

set -euo pipefail

FIREFOX_PROFILE="${HOME}/.mozilla/firefox/unsafe"
NS_NAME="unsafe"
VETH_HOST="veth-unsafe-h"
VETH_NS="veth-unsafe-ns"
NS_IP="10.200.200.2"
GATEWAY="10.200.200.1"

# Create profile if missing with privacy config
if [ ! -d "$FIREFOX_PROFILE" ]; then
  mkdir -p "$FIREFOX_PROFILE"
  cat > "${FIREFOX_PROFILE}/user.js" << 'EOF'
user_pref("network.proxy.socks", "");
user_pref("network.proxy.socks_port", 0);
user_pref("network.proxy.type", 0);
user_pref("privacy.clearOnShutdown.history", true);
user_pref("privacy.clearOnShutdown.cookies", true);
user_pref("privacy.clearOnShutdown.cache", true);
user_pref("browser.startup.homepage", "about:blank");
user_pref("signon.rememberSignons", false);
user_pref("browser.formfill.enable", false);
user_pref("toolkit.telemetry.enabled", false);
user_pref("browser.shell.checkDefaultBrowser", false);
user_pref("network.trr.mode", 5);
EOF
fi

cleanup() {
  ip netns del "$NS_NAME" 2>/dev/null || true
  ip link del "$VETH_HOST" 2>/dev/null || true
  iptables -D POSTROUTING -t nat -s "$NS_IP/24" -j MASQUERADE 2>/dev/null || true
}
trap cleanup EXIT

# Set up network namespace with direct Internet access
ip netns add "$NS_NAME" 2>/dev/null || true
ip link add "$VETH_HOST" type veth peer name "$VETH_NS" 2>/dev/null || true
ip link set "$VETH_NS" netns "$NS_NAME" 2>/dev/null || true
ip addr add "$GATEWAY/24" dev "$VETH_HOST" 2>/dev/null || true
ip link set "$VETH_HOST" up 2>/dev/null || true
ip netns exec "$NS_NAME" ip addr add "$NS_IP/24" dev "$VETH_NS" 2>/dev/null || true
ip netns exec "$NS_NAME" ip link set "$VETH_NS" up 2>/dev/null || true
ip netns exec "$NS_NAME" ip link set lo up 2>/dev/null || true
ip netns exec "$NS_NAME" ip route add default via "$GATEWAY" 2>/dev/null || true
iptables -t nat -A POSTROUTING -s "$NS_IP/24" -j MASQUERADE 2>/dev/null || true
sysctl -w net.ipv4.ip_forward=1 &>/dev/null || true

# Show warning
notify-send -u critical "⚠ UNSAFE BROWSER" "Direct networking — NOT routed through Tor." -t 5000
echo ""
echo "  ╔══════════════════════════════════════════════════╗"
echo "  ║          UNSAFE BROWSER (DIRECT NET)            ║"
echo "  ║     Traffic bypasses Tor completely             ║"
echo "  ║     Use ONLY for local/captive portal access    ║"
echo "  ╚══════════════════════════════════════════════════╝"
echo ""

exec ip netns exec "$NS_NAME" firefox --no-remote --profile "$FIREFOX_PROFILE" "$@"
