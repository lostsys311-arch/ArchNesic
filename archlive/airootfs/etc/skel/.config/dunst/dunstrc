# ArchNesic — Dunst notification daemon config
# Tokyo Night theme — minimal, silent

[global]
  monitor = 0
  follow = keyboard
  width = 350
  height = 200
  origin = top-right
  offset = 10x40
  scale = 0
  notification_limit = 5
  progress_bar = true
  progress_bar_height = 8
  progress_bar_frame_width = 1
  progress_bar_min_value = 0
  progress_bar_max_value = 100
  indicate_hidden = yes
  transparency = 10
  shrink = yes
  separator_height = 2
  padding = 12
  horizontal_padding = 10
  text_icon_padding = 6
  frame_width = 1
  frame_color = "#3b4261"
  separator_color = "#3b4261"
  sort = yes
  idle_threshold = 60
  font = "JetBrains Mono Nerd Font 10"
  line_height = 0
  markup = full
  format = "<b>%s</b>\n%b"
  alignment = left
  vertical_alignment = center
  show_age_threshold = 60
  word_wrap = yes
  ellipsize = middle
  ignore_newline = no
  stack_duplicates = true
  hide_duplicate_count = false
  show_indicators = yes
  icon_position = left
  min_icon_size = 24
  max_icon_size = 64
  icon_path = /usr/share/icons/hicolor/48x48/status/:/usr/share/icons/hicolor/48x48/devices/
  sticky_history = yes
  history_length = 20
  dmenu = /usr/bin/rofi -dmenu -p dunst
  browser = /usr/bin/firefox
  always_run_script = true
  title = Dunst
  class = Dunst
  corner_radius = 6
  ignore_dbusclose = false
  force_x11 = false
  mouse_left = close_current
  mouse_middle = do_action
  mouse_right = close_all

[experimental]
  per_monitor_show = no

[shortcuts]
  close = control+space
  close_all = control+shift+space
  history = control+grave
  context = control+shift+period

[urgency_low]
  background = "#1a1b26"
  foreground = "#a9b1d6"
  timeout = 5
  frame_color = "#3b4261"

[urgency_normal]
  background = "#1a1b26"
  foreground = "#c0caf5"
  timeout = 8
  frame_color = "#7aa2f7"

[urgency_critical]
  background = "#1a1b26"
  foreground = "#f7768e"
  timeout = 0
  frame_color = "#f7768e"
  icon = /usr/share/icons/hicolor/48x48/status/dialog-warning.png
