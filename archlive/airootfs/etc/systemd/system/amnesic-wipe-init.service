[Unit]
Description=Amnesic Wipe — first-boot initialisation
DefaultDependencies=no
After=systemd-sysusers.service
Before=sysinit.target
ConditionPathExists=!/var/lib/amnesic-initialized

[Service]
Type=oneshot
ExecStart=/usr/local/bin/amnesic-init.sh
ExecStartPost=/usr/bin/touch /var/lib/amnesic-initialized
RemainAfterExit=yes

[Install]
WantedBy=sysinit.target
