# ArchNesic (v3) — Transparent Tor firewall with NAT redirect
# All non-Tor output is blocked.
# Only UID 42 (Tor) may route through the default gateway.
# TCP traffic is transparently redirected through Tor's TransPort.
# DNS is forced through Tor's DNSPort.

# ── NAT table — redirect traffic through Tor ─────
*nat
:PREROUTING ACCEPT [0:0]
:INPUT ACCEPT [0:0]
:OUTPUT ACCEPT [0:0]
:POSTROUTING ACCEPT [0:0]

# Redirect all TCP traffic through Tor's TransPort (9040)
# Exclude UID 42 (Tor itself)
-A OUTPUT -p tcp -m owner --uid-owner 42 -j RETURN
-A OUTPUT -p tcp -d 127.0.0.0/8 -j RETURN
-A OUTPUT -p tcp --dport 9040 -j RETURN
-A OUTPUT -p tcp -j REDIRECT --to-ports 9040

# Redirect DNS through Tor's DNSPort (5353)
# Exclude UID 42
-A OUTPUT -p udp --dport 53 -m owner --uid-owner 42 -j RETURN
-A OUTPUT -p udp --dport 53 -d 127.0.0.0/8 -j RETURN
-A OUTPUT -p udp --dport 53 -j REDIRECT --to-ports 5353
-A OUTPUT -p tcp --dport 53 -j REDIRECT --to-ports 5353

COMMIT

# ── Filter table — block non-Tor traffic ────────
*filter
:INPUT DROP [0:0]
:FORWARD DROP [0:0]
:OUTPUT DROP [0:0]

# Loopback — allow everything
-A INPUT -i lo -j ACCEPT
-A OUTPUT -o lo -j ACCEPT

# Existing / established — accept
-A INPUT -m conntrack --ctstate ESTABLISHED,RELATED -j ACCEPT
-A OUTPUT -m conntrack --ctstate ESTABLISHED,RELATED -j ACCEPT

# Tor traffic (via TUN, UID 42) — allow
-A OUTPUT -o tun+ -j ACCEPT
-A OUTPUT -m owner --uid-owner 42 -j ACCEPT

# ICMP (rate-limited) — allow
-A OUTPUT -p icmp -m conntrack --ctstate NEW -m limit --limit 2/sec -j ACCEPT

# Log dropped packets
-A OUTPUT -m limit --limit 5/min -j LOG --log-prefix "TOR-BLOCK: " --log-level 4

COMMIT
